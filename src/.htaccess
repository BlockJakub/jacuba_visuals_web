# ==========================================================================
# JACUBA VISUALS WEB - XAMPP LOCAL ERROR PAGES
# ==========================================================================

ErrorDocument 404 /jacubavisualsweb/404.html
ErrorDocument 403 /jacubavisualsweb/403.html
ErrorDocument 500 /jacubavisualsweb/500.html

RewriteEngine On

# Test 403 Forbidden response
RewriteRule ^test-403$ - [F,L]

# Test 500 Internal Server Error response
RewriteRule ^test-500$ - [R=500,L]